# Required
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/<db_name>
SECRET_KEY=<strong-secret>
LOCAL_SLM_BASE_URL=http://<model-host>:8080
ALLOWED_ORIGINS=https://iwerp.com

# Strongly recommended for deployment portability
IWERP_BASE_DIR=/home/site/wwwroot
IWFUSION_INFERENCE_BACKEND=llama_cpp
IWFUSION_MODEL_NAME=IWFUSION-SLM-V1
IWFUSION_USE_RERANKER=false
IWFUSION_USE_EMBEDDINGS=true

# Optional
IWFUSION_ENABLE_LEGACY_OPENAI_ROUTES=false
REDIS_URL=redis://<redis-host>:6379/0
LLAMA_CPP_BASE_URL=http://<model-host>:8080
IWFUSION_MAX_NEW_TOKENS=1024
IWFUSION_CTX_SIZE=8192
IWFUSION_THREADS=8
IWFUSION_TEMPERATURE=0.0
IWFUSION_TOP_P=0.9
